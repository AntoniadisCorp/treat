    "@angular/forms": "^17.2.1",
    "@angular/platform-browser": "^17.2.1",
    "@angular/platform-browser-dynamic": "^17.2.1",
    "@angular/platform-server": "^17.2.1",
    "@angular/router": "^17.2.1",
    "@angular/ssr": "^17.2.0",
    "@better-auth/infra": "^0.1.12",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^0.8.1",
    "better-auth": "^1.5.6",
    "elysia": "^0.8.16",
    "ngxtension": "^2.0.0",
