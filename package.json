{
  "name": "treaty",
  "version": "0.1.0-next.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "watch:prod": "ng build --watch --configuration production",
    "smoke:auth": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke-auth-routes.ps1",
