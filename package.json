    "prepare": "husky",
    "release:prepare": "bunx semantic-release --no-ci --dry-run",
    "release": "bunx semantic-release"
  },
  "dependencies": {
    "@angular/animations": "^17.2.1",
    "@angular/common": "^17.2.1",
    "@angular/compiler": "^17.2.1",
